{
  "name": "matchday-mcp",
  "version": "0.1.0",
  "description": "MCP server for live football data (teams, fixtures, results, standings) powered by TheSportsDB. Built with TypeScript and Zod.",
  "license": "MIT",
  "author": "Reinaldo Orozco",
  "type": "module",
  "homepage": "https://github.com/reiorozco/matchday-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reiorozco/matchday-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/reiorozco/matchday-mcp/issues"
  },
  "bin": {
    "matchday-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "football",
    "soccer",
    "thesportsdb",
    "ai-tools",
    "zod"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
